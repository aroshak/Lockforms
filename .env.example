# =============================================================================
# LockForms.io — Environment Variables
# Copy this to .env and fill in your values
# =============================================================================

# --- Database ---
DATABASE_URL="postgresql://lockforms:change_me@localhost:5432/lockforms?schema=public"
POSTGRES_USER=lockforms
POSTGRES_PASSWORD=change_me
POSTGRES_DB=lockforms

# --- App ---
NODE_ENV=production
APP_PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
DEPLOYMENT_MODE=appliance

# --- NextAuth (Native Authentication) ---
# Generate: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change_me_in_production_32chars!!

# --- License (appliance mode only) ---
LICENSE_KEY=
